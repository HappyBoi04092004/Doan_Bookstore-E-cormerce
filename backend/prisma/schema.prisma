generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     Role   @default(USER)

  createdAt DateTime @default(now())
}

model Category {
  id   String @id @default(uuid())
  name String

  products Product[]
}

model Product {
  id    String @id @default(uuid())
  title String
  price Float

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
}