generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String?
  googleId  String?    @unique
  avatar    String?
  name      String
  roleId    Int
  role      Role       @relation(fields: [roleId], references: [id])
  orders    Order[]
  reviews   Review[]
  cart      Cart?
  addresses Address[]
  wishlist  Wishlist[]
  createdAt DateTime   @default(now())
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String
  users User[]
}

model Category {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  image String?
  books Book[]  @relation("CategoryBooks")
}

model Author {
  id    Int    @id @default(autoincrement())
  name  String
  books Book[]
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  authorId    Int
  price       Int
  stock       Int
  description String?
  categoryId  Int
  createdAt   DateTime @default(now())

  images     BookImage[]
  attributes BookAttribute[]
  variants   BookVariant[]

  author     Author      @relation(fields: [authorId], references: [id])
  category   Category    @relation("CategoryBooks", fields: [categoryId], references: [id])
  reviews    Review[]
}

model BookVariant {
  id              Int      @id @default(autoincrement())
  bookId    Int
  name      String   // e.g., "Bản đặc biệt", "Bản thường"
  sku       String?  @unique
  price     Int
  stock     Int
  discountPercent Int?
  
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  cartItems CartItem[]
  orderItems OrderItem[]
  wishlists Wishlist[]
  images    BookImage[]

  @@index([bookId])
}


model Cart {
  id     Int        @id @default(autoincrement())
  userId Int        @unique
  user   User       @relation(fields: [userId], references: [id])
  items  CartItem[]
}

model CartItem {
  id        Int @id @default(autoincrement())
  cartId    Int
  variantId Int
  qty       Int

  cart    Cart        @relation(fields: [cartId], references: [id])
  variant BookVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
}


model Order {
  id             Int     @id @default(autoincrement())
  userId         Int
  status         String // PENDING | PAID | CANCELLED | FAILED
  total          Int
  idempotencyKey String? @unique

  paymentMethod String? // MOMO | COD
  paymentStatus String? // PENDING | SUCCESS | FAILED

  items   OrderItem[]
  payment Payment?

  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model OrderItem {
  id        Int @id @default(autoincrement())
  orderId   Int
  variantId Int
  qty       Int
  price     Int

  order   Order       @relation(fields: [orderId], references: [id])
  variant BookVariant @relation(fields: [variantId], references: [id])
}


model Review {
  id      Int    @id @default(autoincrement())
  rating  Int
  comment String
  userId  Int
  bookId  Int

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])
}

model Payment {
  id      Int @id @default(autoincrement())
  orderId Int @unique

  method String // MOMO, COD
  status String // PENDING, SUCCESS, FAILED

  transactionId String?
  amount        Int?

  order Order @relation(fields: [orderId], references: [id])
}

model Province {
  code      Int        @id
  name      String
  districts District[]
  addresses Address[]

  @@index([name])
}

model District {
  code         Int       @id
  name         String
  provinceCode Int
  province     Province  @relation(fields: [provinceCode], references: [code])
  wards        Ward[]
  addresses    Address[]

  @@index([name])
  @@index([provinceCode])
}

model Ward {
  code         Int       @id
  name         String
  districtCode Int
  district     District  @relation(fields: [districtCode], references: [code])
  addresses    Address[]

  @@index([name])
  @@index([districtCode])
}

model Address {
  id           Int    @id @default(autoincrement())
  userId       Int
  name         String
  phone        String
  provinceCode Int
  districtCode Int
  wardCode     Int
  detail       String

  user     User     @relation(fields: [userId], references: [id])
  province Province @relation(fields: [provinceCode], references: [code])
  district District @relation(fields: [districtCode], references: [code])
  ward     Ward     @relation(fields: [wardCode], references: [code])
}

model Coupon {
  id       Int    @id @default(autoincrement())
  code     String @unique
  discount Int
}

model Wishlist {
  id        Int @id @default(autoincrement())
  userId    Int
  variantId Int

  user    User        @relation(fields: [userId], references: [id])
  variant BookVariant @relation(fields: [variantId], references: [id])

  @@unique([userId, variantId])
}


// ─── Product Images ────────────────────────────────────────────────────────────

model BookImage {
  id        Int     @id @default(autoincrement())
  bookId    Int
  variantId Int?
  url       String
  altText   String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  book    Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  variant BookVariant? @relation(fields: [variantId], references: [id])

  @@index([bookId])
  @@index([variantId])
}


// ─── Product Attributes (3-table reusable EAV) ─────────────────────────────────
// Attribute: defines the attribute type (e.g., "Format", "Language", "Pages")
// BookAttribute: joins a Book with an Attribute and stores its value

model Attribute {
  id   Int     @id @default(autoincrement())
  name String  @unique // e.g., "Language", "Format", "Publisher"
  unit String? // optional unit, e.g., "pages", "mm"

  bookAttributes BookAttribute[]
}

model BookAttribute {
  id          Int    @id @default(autoincrement())
  bookId      Int
  attributeId Int
  value       String // e.g., "English", "Paperback", "320"

  book      Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id])

  @@unique([bookId, attributeId])
  @@index([bookId])
  @@index([attributeId])
}
