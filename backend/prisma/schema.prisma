generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql" // hoặc postgresql nếu ông dùng pg
}

enum Role {
  ADMIN
  USER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  orders    Order[]
  createdAt DateTime @default(now())
}

model Product {
  id          String   @id @default(uuid())
  title       String
  author      String
  price       Float
  description String?
  createdAt   DateTime @default(now())
}

model Order {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  total     Float
  createdAt DateTime @default(now())
}
